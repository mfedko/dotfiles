"*":
  autosave:
    enabled: true
  core:
    disabledPackages: [
      "background-tips"
      "exception-reporting"
      "metrics"
    ]
    followSymlinks: false
    hideGitIgnoredFiles: true
    ignoredNames: [
      ".bundle"
      ".git"
      "log"
      "repositories"
      "tmp"
      "vendor"
    ]
    telemetryConsent: "limited"
    themes: [
      "one-dark-ui"
      "base16-tomorrow-dark-theme"
    ]
  editor:
    fontFamily: "Fira Code"
    fontSize: 12
    invisibles: {}
    preferredLineLength: 120
    showIndentGuide: true
    softWrap: true
    tabLength: 4
  "git-plus":
    general:
      _analyticsUserId: "96d7c232-b38e-4b00-b0fd-65a44996f01d"
  "go-plus":
    goPath: "/Users/holman/Code/go"
  "linter-eslint":
    useGlobalEslint: true
  "release-notes":
    viewedVersion: "0.89.0"
  "spell-check":
    grammars: [
      "text.plain"
      "source.gfm"
      "text.git-commit"
      "text.html.basic"
    ]
  "terminal-plus":
    core:
      shell: "/bin/bash"
      workingDirectory: "Active File"
  welcome:
    showOnStartup: false
".diff":
  editor:
    tabLength: 4
".groovy.source":
  editor:
    tabLength: 4
